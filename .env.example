# === Google Sheets / Drive ===
# מזהה הגיליון (מתוך כתובת ה-URL של הגיליון)
GOOGLE_SHEET_ID=

# תיקיית Google Drive לתמונות (מזהה התיקייה מה-URL)
GOOGLE_DRIVE_FOLDER_ID=

# חשבון שירות (Service Account) — הדבק את כל תוכן קובץ ה-JSON בשורה אחת,
# או ציין נתיב לקובץ במקום זה.
GOOGLE_SERVICE_ACCOUNT_JSON=
# GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./service-account.json

# === Claude Vision (חילוץ טקסט משער) — שלב 2 ===
ANTHROPIC_API_KEY=

# === Google Books (השלמת ISBN) — שלב 3, לרוב לא דורש מפתח ===
# GOOGLE_BOOKS_API_KEY=
